{
  "name": "@sapiom/harness",
  "version": "0.1.1",
  "description": "Sapiom Harness — a CLI-launched local web app that runs your coding agent (Claude Code, Codex) in a Sapiom-configured environment: MCP pre-wired, workflows tracked, one-click deploy/run, and a live canvas for previews.",
  "keywords": [
    "sapiom",
    "harness",
    "claude",
    "codex",
    "terminal",
    "workflows"
  ],
  "homepage": "https://github.com/sapiom/sapiom-js/tree/main/packages/harness#readme",
  "bugs": {
    "url": "https://github.com/sapiom/sapiom-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sapiom/sapiom-js.git",
    "directory": "packages/harness"
  },
  "license": "MIT",
  "author": "Sapiom",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sapiom-harness": "./dist/cli/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json && vite build --config web/vite.config.ts",
    "build:server": "tsc --project tsconfig.build.json",
    "build:web": "vite build --config web/vite.config.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx src/cli/bin.ts --dev",
    "dev:web": "vite --config web/vite.config.ts",
    "start": "node dist/cli/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "playwright test --config web/e2e/playwright.config.ts",
    "test:canvas": "playwright test --config e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "pnpm build",
    "mock-collector": "node scripts/mock-collector.mjs",
    "sim:e2e": "tsx scripts/e2e-sim.ts",
    "seed-example": "node scripts/seed-example.mjs",
    "e2e:live": "tsx scripts/e2e-live.ts"
  },
  "dependencies": {
    "@sapiom/agent": "workspace:^",
    "@sapiom/agent-core": "workspace:^",
    "@sapiom/mcp": "workspace:^",
    "express": "^4.21.0",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
